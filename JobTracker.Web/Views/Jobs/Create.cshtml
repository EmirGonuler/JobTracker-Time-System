@{
    ViewData["Title"] = "Create New Job";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create New Job</h4>
                </div>

                <div class="card-body">

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["ErrorMessage"]
                        </div>
                    }

                    @*
                        asp-controller and asp-action tell this form where to submit to.
                        This will POST to JobsController.Create()
                    *@
                    <form asp-controller="Jobs" asp-action="Create" method="post">

                        @*
                            This hidden field is a security token.
                            It prevents attackers from submitting fake forms.
                            Always include this in every form.
                        *@
                        @Html.AntiForgeryToken()

                        @* ── Job Type dropdown ── *@
                        <div class="mb-3">
                            <label for="jobType" class="form-label fw-bold">Job Type</label>
                            <select name="jobType" id="jobType" class="form-select" required>
                                <option value="">-- Select Job Type --</option>
                                @*
                                    We loop through the JobType enum values to build the dropdown.
                                    This means if you ever add a new job type, it appears automatically.
                                *@
                                @foreach (var type in Enum.GetValues<JobTracker.Core.Enums.JobType>())
                                {
                                    <option value="@type">@type</option>
                                }
                            </select>
                        </div>

                        @* ── Date picker ── *@
                        <div class="mb-3">
                            <label for="date" class="form-label fw-bold">Date</label>
                            <input type="date"
                                   name="date"
                                   id="date"
                                   class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   required />
                        </div>

                        @* ── Client dropdown ── *@
                        <div class="mb-3">
                            <label for="clientId" class="form-label fw-bold">Client</label>
                            @*
                                ViewBag.ClientId was set in PopulateClientDropdown() in the controller.
                                asp-items binds that SelectList to this dropdown automatically.
                            *@
                            <select name="clientId"
                                    id="clientId"
                                    class="form-select"
                                    asp-items="ViewBag.ClientId"
                                    required>
                                <option value="">-- Select Client --</option>
                            </select>
                        </div>

                        @* ── Buttons ── *@
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                Save Job
                            </button>
                            <a asp-controller="Jobs"
                                   asp-action="Index"
                                   class="btn btn-secondary">
                                Cancel
                            </a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>

</div>

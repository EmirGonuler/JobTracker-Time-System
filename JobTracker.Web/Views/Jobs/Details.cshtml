@model JobTracker.Core.Models.Job

@{
    ViewData["Title"] = $"Job Details — {Model.JobNo}";
}

<div class="container mt-4">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Job Details Card ── *@
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Job — @Model.JobNo</h4>
            <a asp-controller="Jobs"
                   asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-sm btn-warning">
                Edit Job
            </a>
        </div>

        <div class="card-body">
            <div class="row">

                @* Left column *@
                <div class="col-md-6">
                    <p>
                        <span class="fw-bold">Job No:</span>
                        @Model.JobNo
                    </p>
                    <p>
                        <span class="fw-bold">Job Type:</span>
                        @if (Model.JobType == JobTracker.Core.Enums.JobType.Repair)
                        {
                            <span class="badge bg-danger">Repair</span>
                        }
                        else if (Model.JobType == JobTracker.Core.Enums.JobType.Support)
                        {
                            <span class="badge bg-primary">Support</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Warranty</span>
                        }
                    </p>
                    <p>
                        <span class="fw-bold">Date:</span>
                        @Model.Date.ToString("dd MMM yyyy")
                    </p>
                </div>

                @* Right column — Client info *@
                <div class="col-md-6">
                    <p>
                        <span class="fw-bold">Company:</span>
                        @Model.Client?.CompanyName
                    </p>
                    <p>
                        <span class="fw-bold">Contact:</span>
                        @Model.Client?.ContactName
                    </p>
                    <p>
                        <span class="fw-bold">Phone:</span>
                        @Model.Client?.PhoneNumber
                    </p>
                </div>

            </div>
        </div>
    </div>

    @* ── Time Cards Section ── *@
    <div class="card shadow-sm">
        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Time Cards</h5>
            @*
                This button links to the clock-in form.
                asp-route-jobId passes the current job's ID to TimeCardsController.Create()
            *@
            <a asp-controller="TimeCards"
                   asp-action="Create"
                   asp-route-jobId="@Model.Id"
                   class="btn btn-sm btn-light">
                + Clock In
            </a>
        </div>

        <div class="card-body">
            @if (Model.TimeCards == null || !Model.TimeCards.Any())
            {
                <p class="text-muted">No time cards logged for this job yet.</p>
            }
            else
            {
                <table class="table table-striped table-hover">
                    <thead class="table-secondary">
                        <tr>
                            <th>Employee</th>
                            <th>Date Worked</th>
                            <th>Hours Worked</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tc in Model.TimeCards)
                        {
                            <tr>
                                <td>@tc.Employee?.FullName</td>
                                <td>@tc.DateWorked.ToString("dd MMM yyyy")</td>
                                <td>@tc.HoursWorked hrs</td>
                                <td>
                                    @*
                                        Each time card gets its own small delete form.
                                        We use a form with POST — never a link — for deletions.
                                        A link (GET request) could be triggered accidentally
                                        or by a web crawler, deleting data unintentionally.
                                    *@
                                    <form asp-controller="TimeCards"
                                          asp-action="Delete"
                                          method="post"
                                          style="display:inline"
                                          onsubmit="return confirm('Remove this time card? This cannot be undone.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@tc.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary">
                        <tr>
                            <td colspan="2"><strong>Total Hours</strong></td>
                            <td><strong>@Model.TimeCards.Sum(tc => tc.HoursWorked) hrs</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            }
        </div>
    </div>

    @* ── Back button ── *@
    <div class="mt-3">
        <a asp-controller="Jobs" asp-action="Index" class="btn btn-secondary">
            Back to Jobs List
        </a>
    </div>

</div>

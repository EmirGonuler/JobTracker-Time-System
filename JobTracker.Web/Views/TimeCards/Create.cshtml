@{
    ViewData["Title"] = "Clock In Time Card";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">Clock In — Log Hours</h4>
                </div>

                <div class="card-body">

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["ErrorMessage"]
                        </div>
                    }

                    <form asp-controller="TimeCards" asp-action="Create" method="post">

                        @Html.AntiForgeryToken()

                        @*
                            This hidden field carries the jobId silently through the form.
                            The user never sees it but the controller needs it to know
                            which job this time card belongs to.
                        *@
                        <input type="hidden" name="jobId" value="@ViewBag.JobId" />

                        @* ── Employee dropdown ── *@
                        <div class="mb-3">
                            <label for="employeeId" class="form-label fw-bold">Employee</label>
                            <select name="employeeId"
                                    id="employeeId"
                                    class="form-select"
                                    asp-items="ViewBag.EmployeeId"
                                    required>
                                <option value="">-- Select Employee --</option>
                            </select>
                        </div>

                        @* ── Date Worked ── *@
                        <div class="mb-3">
                            <label for="dateWorked" class="form-label fw-bold">Date Worked</label>
                            <input type="date"
                                   name="dateWorked"
                                   id="dateWorked"
                                   class="form-control"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")"
                                   required />
                        </div>

                        @* ── Hours Worked ── *@
                        <div class="mb-3">
                            <label for="hoursWorked" class="form-label fw-bold">
                                Hours Worked
                            </label>
                            <input type="number"
                                   name="hoursWorked"
                                   id="hoursWorked"
                                   class="form-control"
                                   min="0.5"
                                   max="24"
                                   step="0.5"
                                   placeholder="e.g. 7.5"
                                   required />
                            <small class="text-muted">
                                Enter hours in 0.5 increments (e.g. 7.5 for 7 and a half hours)
                            </small>
                        </div>

                        @* ── Buttons ── *@
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-secondary">
                                Clock In
                            </button>
                            @*
                                Cancel goes back to that specific job's details page
                            *@
                            <a asp-controller="Jobs"
                                   asp-action="Details"
                                   asp-route-id="@ViewBag.JobId"
                                   class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>

</div>
